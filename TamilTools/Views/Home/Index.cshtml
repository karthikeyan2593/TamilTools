                    sectionTitle: "எங்கள் கருவிகள்",

                    tool1Name: "EMI கணக்கீடு",
                    tool1Desc: "கடன் மாத தவணை கணக்கிடுங்கள்",
                    tool1Tag: "நிதி",

                    tool2Name: "சம்பள கணக்கீடு",
                    tool2Desc: "கையில் கிடைக்கும் சம்பளம் கணக்கிடுங்கள்",
                    tool2Tag: "நிதி",

                    tool3Name: "படம் to PDF",
                    tool3Desc: "படங்களை PDF-ஆக மாற்றுங்கள்",
                    tool3Tag: "PDF",

                    tool4Name: "நாணய மாற்றி",
                    tool4Desc: "உலக நாணயங்களை மாற்றுங்கள்",
                    tool4Tag: "நாணயம்",

                    tool5Name: "நட்சத்திர பொருத்தம்",
                    tool5Desc: "திருமண பொருத்தம் கண்டறியுங்கள்",
                    tool5Tag: "ஜோதிடம்",

                    tool6Name: "Tamil செய்திகள்",
                    tool6Desc: "தினமும் புதிய Tamil செய்திகள் — Auto Updated!",
                    tool6Tag: "செய்திகள்"
                },

                en: {
                    heroTitle: "🛠️ TamilTools",
                    heroSubtitle: "Free Online Tools — In Tamil!",
                    sectionTitle: "Our Tools",

                    tool1Name: "EMI Calculator",
                    tool1Desc: "Calculate your loan EMI instantly",
                    tool1Tag: "Finance",

                    tool2Name: "Salary Calculator",
                    tool2Desc: "Calculate your in-hand salary",
                    tool2Tag: "Finance",

                    tool3Name: "Image to PDF",
                    tool3Desc: "Convert images to PDF easily",
                    tool3Tag: "PDF",

                    tool4Name: "Currency Converter",
                    tool4Desc: "Convert world currencies instantly",
                    tool4Tag: "Currency",

                    tool5Name: "Horoscope Matching",
                    tool5Desc: "Find marriage compatibility",
                    tool5Tag: "Astrology",

                    tool6Name: "Tamil News",
                    tool6Desc: "Daily Tamil news — Auto Updated!",
                    tool6Tag: "News"
                },

                hi: {
                    heroTitle: "🛠️ TamilTools",
                    heroSubtitle: "मुफ्त ऑनलाइन टूल्स!",
                    sectionTitle: "हमारे टूल्स",

                    tool1Name: "EMI कैलकुलेटर",
                    tool1Desc: "लोन की मासिक किस्त जानें",
                    tool1Tag: "वित्त",

                    tool2Name: "वेतन कैलकुलेटर",
                    tool2Desc: "इन-हैंड सैलरी जानें",
                    tool2Tag: "वित्त",

                    tool3Name: "इमेज to PDF",
                    tool3Desc: "तस्वीरें PDF में बदलें",
                    tool3Tag: "PDF",

                    tool4Name: "मुद्रा परिवर्तक",
                    tool4Desc: "विश्व मुद्राएं बदलें",
                    tool4Tag: "मुद्रा",

                    tool5Name: "कुंडली मिलान",
                    tool5Desc: "विवाह अनुकूलता जांचें",
                    tool5Tag: "ज्योतिष",

                    tool6Name: "Tamil समाचार",
                    tool6Desc: "रोज़ाना Tamil समाचार — Auto Updated!",
                    tool6Tag: "समाचार"
                }
            };

            function setLang(lang) {

                const t = text[lang];

                const ids = [
                    'heroTitle',
                    'heroSubtitle',
                    'sectionTitle',

                    'tool1Name',
                    'tool1Desc',
                    'tool1Tag',

                    'tool2Name',
                    'tool2Desc',
                    'tool2Tag',

                    'tool3Name',
                    'tool3Desc',
                    'tool3Tag',

                    'tool4Name',
                    'tool4Desc',
                    'tool4Tag',

                    'tool5Name',
                    'tool5Desc',
                    'tool5Tag',

                    'tool6Name',
                    'tool6Desc',
                    'tool6Tag'
                ];

                ids.forEach(id => {

                    const el = document.getElementById(id);

                    if (el) {
                        el.innerText = t[id];
                    }
                });

                ['ta', 'en', 'hi'].forEach(l => {

                    document.getElementById('btn-' + l)
                        .classList.toggle('active', l === lang);
                });
            }

    </script>

</body>
</html>