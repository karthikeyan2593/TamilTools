@{
    ViewData["Title"] = "TamilTools - Free Online Tools in Tamil";
    ViewData["Description"] = "Free premium online calculators and utility tools in Tamil.";
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <meta name="description"
          content="TamilTools offers free online calculators, converters, finance tools, PDF tools and more in Tamil." />

    <title>TamilTools</title>

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: #050816;
                color: white;
                overflow-x: hidden;
            }

            a {
                text-decoration: none;
            }

            .hero {
                padding: 90px 20px;
                text-align: center;
                background: linear-gradient(135deg,#4f46e5,#7c3aed);
            }

                .hero h1 {
                    font-size: 58px;
                    font-weight: 800;
                    margin-bottom: 14px;
                }

                .hero p {
                    font-size: 18px;
                    opacity: 0.9;
                }

            .tools-section {
                max-width: 1350px;
                margin: auto;
                padding: 60px 20px;
            }

            .section-title {
                text-align: center;
                font-size: 30px;
                font-weight: 800;
                margin-bottom: 45px;
            }

            .tools-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit,minmax(270px,1fr));
                gap: 28px;
            }

            .tool-card {
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 24px;
                padding: 30px;
                transition: 0.3s ease;
                color: white;
                min-height: 260px;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
            }

                .tool-card:hover {
                    transform: translateY(-8px);
                    border-color: #6366f1;
                    box-shadow: 0 20px 40px rgba(99,102,241,0.25);
                }

            .tool-icon {
                font-size: 46px;
                margin-bottom: 18px;
            }

            .tool-name {
                font-size: 26px;
                font-weight: 700;
                margin-bottom: 12px;
                line-height: 1.3;
            }

            .tool-desc {
                color: rgba(255,255,255,0.72);
                line-height: 1.7;
                font-size: 15px;
                margin-bottom: 22px;
            }

            .tool-tag {
                display: inline-block;
                padding: 7px 15px;
                border-radius: 30px;
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.6px;
                width: fit-content;
            }

            .tag-finance {
                background: rgba(79,70,229,0.22);
                color: #8b5cf6;
            }

            .tag-health {
                background: rgba(34,197,94,0.20);
                color: #22c55e;
            }

            .tag-utility {
                background: rgba(249,115,22,0.20);
                color: #f97316;
            }

            .tag-pdf {
                background: rgba(236,72,153,0.20);
                color: #ec4899;
            }

            .tag-news {
                background: rgba(239,68,68,0.20);
                color: #ef4444;
            }

            .tag-astro {
                background: rgba(168,85,247,0.20);
                color: #c084fc;
            }

            footer {
                margin-top: 70px;
                padding: 30px;
                text-align: center;
                border-top: 1px solid rgba(255,255,255,0.08);
                color: rgba(255,255,255,0.5);
            }

            @@media(max-width:768px) {

                .hero h1 {
                    font-size: 42px;
                }

                .section-title {
                    font-size: 24px;
                }

                .tool-card {
                    min-height: auto;
                }
            }

    </style>

</head>

<body>

    <div class="hero">

        <h1>
            🛠️ TamilTools
        </h1>

        <p>
            Free Premium Online Tools in Tamil
        </p>

    </div>

    <div class="tools-section">

        <div class="section-title">
            Explore Our Tools
        </div>

        <div class="tools-grid">

            <!-- EMI -->
            <a href="/Emi/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">🏦</div>

                    <div class="tool-name">
                        EMI Calculator
                    </div>

                    <div class="tool-desc">
                        Calculate monthly EMI payments for loans instantly.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    FINANCE
                </span>

            </a>

            <!-- Salary -->
            <a href="/Salary/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">💼</div>

                    <div class="tool-name">
                        Salary Calculator
                    </div>

                    <div class="tool-desc">
                        Estimate net salary, deductions and monthly income.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    SALARY
                </span>

            </a>

            <!-- Mortgage -->
            <a href="/Mortgage/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">🏠</div>

                    <div class="tool-name">
                        Mortgage Calculator
                    </div>

                    <div class="tool-desc">
                        Calculate monthly home loan payment instantly.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    MORTGAGE
                </span>

            </a>

            <!-- LiquidationPrice -->

            <a href="/LiquidationPrice/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">
                        ⚠️
                    </div>

                    <div class="tool-name">
                        Liquidation Calculator
                    </div>

                    <div class="tool-desc">
                        Calculate liquidation price for crypto futures trades.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    CRYPTO
                </span>

            </a>

            <!-- Crypto Position Size Calculator -->

            <a href="/CryptoPositionSize/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">
                        ₿
                    </div>

                    <div class="tool-name">
                        Position Size Calculator
                    </div>

                    <div class="tool-desc">
                        Calculate crypto trade size, leverage and risk management instantly.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    CRYPTO
                </span>

            </a>

            <a href="/CryptoProfit" class="tool-card">

                <div class="tool-icon">
                    ₿
                </div>

                <h3>
                    Spot Profit
                </h3>

                <p>
                    Calculate spot trading profit
                    and ROI instantly.
                </p>

                <span>
                    CRYPTO
                </span>

            </a>


            <a href="/FuturesPnL" class="tool-card">

                <div class="tool-icon">
                    💹
                </div>

                <h3>
                    Futures P&amp;L
                </h3>

                <p>
                    Calculate futures profit,
                    loss and ROI instantly.
                </p>

                <span>
                    CRYPTO
                </span>

            </a>

            <!-- SIP -->
            <a href="/SipCalculator/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">💰</div>

                    <div class="tool-name">
                        SIP Calculator
                    </div>

                    <div class="tool-desc">
                        Calculate mutual fund SIP returns and investment growth.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    INVESTMENT
                </span>

            </a>

            <!-- Federal Tax -->
            <a href="/FederalTax/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">💵</div>

                    <div class="tool-name">
                        Federal Tax
                    </div>

                    <div class="tool-desc">
                        Estimate federal income tax and effective tax rate.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    TAX
                </span>

            </a>

            <!-- GST -->
            <a href="/Gst/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">🧾</div>

                    <div class="tool-name">
                        GST Calculator
                    </div>

                    <div class="tool-desc">
                        GST வரியை எளிதாக கணக்கிடுங்கள்.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    GST
                </span>

            </a>

            <!-- Currency -->
            <a href="/Currency/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">💱</div>

                    <div class="tool-name">
                        Currency Converter
                    </div>

                    <div class="tool-desc">
                        Convert global currencies instantly with live rates.
                    </div>

                </div>

                <span class="tool-tag tag-finance">
                    CURRENCY
                </span>

            </a>

            <!-- BMI -->
            <a href="/Bmi/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">⚖️</div>

                    <div class="tool-name">
                        BMI Calculator
                    </div>

                    <div class="tool-desc">
                        Check your Body Mass Index and health status.
                    </div>

                </div>

                <span class="tool-tag tag-health">
                    HEALTH
                </span>

            </a>

            <!-- Unit -->
            <a href="/Unit/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">🔢</div>

                    <div class="tool-name">
                        Unit Converter
                    </div>

                    <div class="tool-desc">
                        Convert weight, temperature, length and more.
                    </div>

                </div>

                <span class="tool-tag tag-utility">
                    UTILITY
                </span>

            </a>

            <!-- PDF -->
            <a href="/Pdf/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">📄</div>

                    <div class="tool-name">
                        Image to PDF
                    </div>

                    <div class="tool-desc">
                        Convert images into PDF documents instantly.
                    </div>

                </div>

                <span class="tool-tag tag-pdf">
                    PDF
                </span>

            </a>

            <!-- Horoscope -->
            <a href="/Horoscope/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">🌟</div>

                    <div class="tool-name">
                        Horoscope Match
                    </div>

                    <div class="tool-desc">
                        திருமண ஜாதக பொருத்தம் பார்க்கலாம்.
                    </div>

                </div>

                <span class="tool-tag tag-astro">
                    ASTRO
                </span>

            </a>

            <!-- News -->
            <a href="/News/Index"
                   class="tool-card">

                <div>

                    <div class="tool-icon">📰</div>

                    <div class="tool-name">
                        Tamil News
                    </div>

                    <div class="tool-desc">
                        Latest Tamil news updates instantly.
                    </div>

                </div>

                <span class="tool-tag tag-news">
                    NEWS
                </span>

            </a>

        </div>

    </div>

    <footer>

        © 2026 TamilTools — அனைத்தும் இலவசம்

    </footer>

</body>

</html>