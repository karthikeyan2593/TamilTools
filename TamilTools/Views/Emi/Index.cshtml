@{
    ViewData["Title"] = "தமிழ் EMI கணக்கீடு | Free EMI Calculator Tamil";

    ViewData["Description"] = "தமிழில் EMI கணக்கிடுங்கள். Home loan, car loan, bike loan மற்றும் personal loan மாத தவணையை உடனே கணக்கிடும் இலவச EMI calculator.";

    ViewData["Keywords"] = "EMI calculator tamil, தமிழ் EMI கணக்கீடு, loan EMI calculator, home loan EMI tamil, மாத தவணை கணக்கு";
}

<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMI Calculator</title>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>

    <style>

        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        font-family: 'Segoe UI', Arial, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 30px 20px;
        }

        .container {
        max-width: 620px;
        margin: 0 auto;
        }

        .lang-toggle {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 16px;
        }

        .lang-btn {
        background: rgba(255,255,255,0.2);
        border-radius: 50px;
        padding: 5px;
        display: flex;
        gap: 4px;
        backdrop-filter: blur(10px);
        }

        .lang-option {
        padding: 7px 18px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: transparent;
        color: rgba(255,255,255,0.7);
        transition: all 0.3s;
        }

        .lang-option.active {
        background: white;
        color: #667eea;
        }

        .card {
        background: white;
        border-radius: 24px;
        padding: 36px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        margin-bottom: 20px;
        position: relative;
        }

        .home-btn {
        position: absolute;
        top: 20px;
        left: 20px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #0f9d94;
        color: white;
        padding: 10px 16px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

        .card-header {
        text-align: center;
        margin-bottom: 32px;
        margin-top: 30px;
        }

        .card-header .icon {
        font-size: 48px;
        margin-bottom: 12px;
        display: block;
        }

        .card-header h1 {
        font-size: 26px;
        color: #1a1a2e;
        font-weight: 800;
        margin-bottom: 6px;
        }

        .card-header p {
        color: #888;
        font-size: 14px;
        }

        .input-group {
        margin-bottom: 20px;
        }

        .input-group label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: #444;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        }

        .input-wrapper {
        position: relative;
        }

        .input-prefix {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-weight: 700;
        font-size: 16px;
        }

        .input-group input {
        width: 100%;
        padding: 14px 14px 14px 36px;
        border: 2px solid #eee;
        border-radius: 12px;
        font-size: 16px;
        transition: all 0.3s;
        color: #1a1a2e;
        font-weight: 600;
        }

        .input-group input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102,126,234,0.1);
        }

        .calc-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        border-radius: 14px;
        font-size: 17px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 8px;
        }

        .calc-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(102,126,234,0.4);
        }

    </style>
</head>

<body>

    <div class="container">

        <div class="lang-toggle">

            <div class="lang-btn">

                <button class="lang-option active"
                        onclick="setLang('ta')"
                        id="btn-ta">
                    தமிழ்
                </button>

                <button class="lang-option"
                        onclick="setLang('en')"
                        id="btn-en">
                    English
                </button>

            </div>

        </div>

        <div class="card">

            <a href="/" class="home-btn">
                ← Home
            </a>

            <div class="card-header">

                <span class="icon">🏦</span>

                <h1 id="title">
                    தமிழ் EMI கணக்கீடு
                </h1>

                <p id="subtitle">
                    உங்கள் மாத தவணை இப்போதே கணக்கிடுங்கள்
                </p>

            </div>

            <form method="post" action="/Emi/Calculate">

                <div class="input-group">

                    <label id="label1">
                        கடன் தொகை
                    </label>

                    <div class="input-wrapper">

                        <span class="input-prefix">₹</span>

                        <input type="number"
                               name="loanAmount"
                               placeholder="500000"
                               value="@ViewBag.InputLoan"
                               required />

                    </div>

                </div>

                <div class="input-group">

                    <label id="label2">
                        வட்டி விகிதம் (% வருடம்)
                    </label>

                    <div class="input-wrapper">

                        <span class="input-prefix">%</span>

                        <input type="number"
                               name="interestRate"
                               step="0.1"
                               placeholder="8.5"
                               value="@ViewBag.InputRate"
                               required />

                    </div>

                </div>

                <div class="input-group">

                    <label id="label3">
                        கடன் காலம் (மாதங்கள்)
                    </label>

                    <div class="input-wrapper">

                        <span class="input-prefix">📅</span>

                        <input type="number"
                               name="months"
                               placeholder="60"
                               value="@ViewBag.InputMonths"
                               required />

                    </div>

                </div>

                <button type="submit"
                        class="calc-btn"
                        id="calcBtn">

                    📊 கணக்கிடு

                </button>

            </form>

        </div>

    </div>

</body>
</html>