@{
    ViewData["Title"] = "Unit Converter - TamilTools";
    ViewData["Description"] = "Free Unit Converter. Convert length, weight, temperature and volume units instantly.";
    ViewData["Keywords"] = "unit converter, length converter, weight converter, temperature converter, US unit converter";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unit Converter</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #f093fb, #f5576c);
            min-height: 100vh;
            padding: 30px 20px;
        }

        .container { max-width: 560px; margin: 0 auto; }

        .home-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.2);
            color: white;
            padding: 10px 16px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 16px;
        }

        .home-btn:hover { background: rgba(255,255,255,0.3); }

        .card {
            background: white;
            border-radius: 24px;
            padding: 36px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        }

        .card-header { text-align: center; margin-bottom: 28px; }
        .card-header .icon { font-size: 48px; margin-bottom: 12px; display: block; }
        .card-header h1 { font-size: 26px; color: #1a1a2e; font-weight: 800; margin-bottom: 6px; }
        .card-header p { color: #888; font-size: 14px; }

        /* Category Tabs */
        .category-tabs {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin-bottom: 24px;
        }

        .cat-btn {
            padding: 10px 8px;
            border: 2px solid #eee;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            background: white;
            color: #888;
            transition: all 0.3s;
            text-align: center;
        }

        .cat-btn.active {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            color: white;
            border-color: transparent;
        }

        .input-group { margin-bottom: 20px; }

        .input-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #444;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-group input, .input-group select {
            width: 100%;
            padding: 14px;
            border: 2px solid #eee;
            border-radius: 12px;
            font-size: 16px;
            color: #1a1a2e;
            font-weight: 600;
            transition: all 0.3s;
        }

        .input-group input:focus, .input-group select:focus {
            outline: none;
            border-color: #f5576c;
            box-shadow: 0 0 0 4px rgba(245,87,108,0.1);
        }

        .unit-row {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 12px;
            align-items: end;
            margin-bottom: 20px;
        }

        .swap-btn {
            background: #f8f9ff;
            border: 2px solid #eee;
            border-radius: 50%;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 18px;
            transition: all 0.3s;
            margin-bottom: 2px;
        }

        .swap-btn:hover { background: #f5576c; color: white; border-color: #f5576c; }

        .calc-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #f093fb, #f5576c);
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
        }

        .calc-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(245,87,108,0.4);
        }

        /* Result */
        .result-box {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            border-radius: 16px;
            padding: 24px;
            text-align: center;
            margin-top: 24px;
            color: white;
        }

        .result-box .from-val { font-size: 14px; opacity: 0.8; margin-bottom: 8px; }
        .result-box .to-val { font-size: 40px; font-weight: 800; }
        .result-box .unit-label { font-size: 13px; opacity: 0.7; margin-top: 4px; }
    </style>
</head>
<body>
<div class="container">

    <a href="/" class="home-btn">← Home</a>

    <div class="card">
        <div class="card-header">
            <span class="icon">🔢</span>
            <h1>Unit Converter</h1>
            <p>Convert length, weight, temperature & volume</p>
        </div>

        <form method="post" action="/Unit/Convert">
            <input type="hidden" name="category" id="categoryInput" value="@(ViewBag.Category ?? "length")" />

            <!-- Category Tabs -->
            <div class="category-tabs">
                <button type="button" class="cat-btn @(ViewBag.Category == null || ViewBag.Category == "length" ? "active" : "")"
                        onclick="setCategory('length')">📏 Length</button>
                <button type="button" class="cat-btn @(ViewBag.Category == "weight" ? "active" : "")"
                        onclick="setCategory('weight')">⚖️ Weight</button>
                <button type="button" class="cat-btn @(ViewBag.Category == "temperature" ? "active" : "")"
                        onclick="setCategory('temperature')">🌡️ Temp</button>
                <button type="button" class="cat-btn @(ViewBag.Category == "volume" ? "active" : "")"
                        onclick="setCategory('volume')">🧪 Volume</button>
            </div>

            <div class="input-group">
                <label>Value</label>
                <input type="number" name="value" placeholder="Enter value"
                    value="@ViewBag.InputValue" step="any" required />
            </div>

            <div class="unit-row">
                <div class="input-group" style="margin-bottom:0;">
                    <label>From</label>
                    <select name="fromUnit" id="fromUnit">
                    </select>
                </div>
                <button type="button" class="swap-btn" onclick="swapUnits()">⇄</button>
                <div class="input-group" style="margin-bottom:0;">
                    <label>To</label>
                    <select name="toUnit" id="toUnit">
                    </select>
                </div>
            </div>

            <button type="submit" class="calc-btn">🔢 Convert</button>
        </form>

        @if (ViewBag.Result != null)
        {
            <div class="result-box">
                <div class="from-val">@ViewBag.Value @ViewBag.FromUnit =</div>
                <div class="to-val">@ViewBag.Result</div>
                <div class="unit-label">@ViewBag.ToUnit</div>
            </div>
        }
    </div>
</div>

<script>
    const units = {
        length: [
            { value: 'inch', label: 'Inch (in)' },
            { value: 'foot', label: 'Foot (ft)' },
            { value: 'yard', label: 'Yard (yd)' },
            { value: 'mile', label: 'Mile (mi)' },
            { value: 'cm', label: 'Centimeter (cm)' },
            { value: 'meter', label: 'Meter (m)' },
            { value: 'km', label: 'Kilometer (km)' }
        ],
        weight: [
            { value: 'pound', label: 'Pound (lb)' },
            { value: 'ounce', label: 'Ounce (oz)' },
            { value: 'ton_us', label: 'US Ton' },
            { value: 'kg', label: 'Kilogram (kg)' },
            { value: 'gram', label: 'Gram (g)' }
        ],
        temperature: [
            { value: 'fahrenheit', label: 'Fahrenheit (°F)' },
            { value: 'celsius', label: 'Celsius (°C)' },
            { value: 'kelvin', label: 'Kelvin (K)' }
        ],
        volume: [
            { value: 'gallon_us', label: 'US Gallon' },
            { value: 'quart', label: 'Quart (qt)' },
            { value: 'pint', label: 'Pint (pt)' },
            { value: 'cup', label: 'Cup' },
            { value: 'fl_oz', label: 'Fluid Ounce (fl oz)' },
            { value: 'liter', label: 'Liter (L)' },
            { value: 'ml', label: 'Milliliter (ml)' }
        ]
    };

    function populateUnits(category, selectedFrom, selectedTo) {
        const fromSel = document.getElementById('fromUnit');
        const toSel = document.getElementById('toUnit');
        fromSel.innerHTML = '';
        toSel.innerHTML = '';

        units[category].forEach((u, i) => {
            const opt1 = new Option(u.label, u.value);
            const opt2 = new Option(u.label, u.value);
            if (selectedFrom ? u.value === selectedFrom : i === 0) opt1.selected = true;
            if (selectedTo ? u.value === selectedTo : i === 1) opt2.selected = true;
            fromSel.appendChild(opt1);
            toSel.appendChild(opt2);
        });
    }

    function setCategory(cat) {
        document.getElementById('categoryInput').value = cat;
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        event.target.classList.add('active');
        populateUnits(cat);
    }

    function swapUnits() {
        const from = document.getElementById('fromUnit');
        const to = document.getElementById('toUnit');
        const temp = from.value;
        from.value = to.value;
        to.value = temp;
    }

    // Initialize
    const currentCat = document.getElementById('categoryInput').value || 'length';
    populateUnits(currentCat, '@ViewBag.FromUnit', '@ViewBag.ToUnit');
</script>
</body>
</html>