@{
    ViewData["Title"] = "Unit Converter - TamilTools";
    ViewData["Description"] = "Free Unit Converter. Convert length, weight, temperature and volume units instantly.";
    ViewData["Keywords"] = "unit converter, length converter, weight converter, temperature converter, US unit converter";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unit Converter</title>
    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', Arial, sans-serif;
                background: linear-gradient( 135deg, #f093fb, #f5576c );
                min-height: 100vh;
                padding: 40px 20px;
            }

            .container {
                width: 100%;
                max-width: 750px;
                margin: 0 auto;
            }

            .home-btn {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: rgba(255,255,255,0.2);
                color: white;
                padding: 12px 18px;
                border-radius: 14px;
                text-decoration: none;
                font-weight: 700;
                font-size: 15px;
                margin-bottom: 20px;
                transition: 0.3s ease;
            }

                .home-btn:hover {
                    background: rgba(255,255,255,0.35);
                    transform: translateY(-2px);
                }

            .card {
                background: rgba(255,255,255,0.95);
                border-radius: 30px;
                padding: 50px;
                box-shadow: 0 25px 70px rgba(0,0,0,0.2);
                backdrop-filter: blur(10px);
                width: 100%;
            }

            .card-header {
                text-align: center;
                margin-bottom: 35px;
            }

                .card-header .icon {
                    font-size: 60px;
                    margin-bottom: 15px;
                    display: block;
                }

                .card-header h1 {
                    font-size: 42px;
                    color: #1a1a2e;
                    font-weight: 800;
                    margin-bottom: 10px;
                }

                .card-header p {
                    color: #666;
                    font-size: 17px;
                }

            /* Category Tabs */

            .category-tabs {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 12px;
                margin-bottom: 30px;
            }

            .cat-btn {
                padding: 14px 10px;
                border: 2px solid #eee;
                border-radius: 16px;
                font-size: 14px;
                font-weight: 700;
                cursor: pointer;
                background: white;
                color: #666;
                transition: all 0.3s;
                text-align: center;
            }

                .cat-btn:hover {
                    transform: translateY(-2px);
                }

                .cat-btn.active {
                    background: linear-gradient( 135deg, #f093fb, #f5576c );
                    color: white;
                    border-color: transparent;
                    box-shadow: 0 8px 20px rgba(245,87,108,0.35);
                }

            .input-group {
                margin-bottom: 24px;
            }

                .input-group label {
                    display: block;
                    font-size: 14px;
                    font-weight: 700;
                    color: #444;
                    margin-bottom: 10px;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

                .input-group input,
                .input-group select {
                    width: 100%;
                    height: 60px;
                    padding: 0 18px;
                    border: 2px solid #eee;
                    border-radius: 16px;
                    font-size: 17px;
                    color: #1a1a2e;
                    font-weight: 600;
                    transition: all 0.3s;
                    background: white;
                }

                    .input-group input:focus,
                    .input-group select:focus {
                        outline: none;
                        border-color: #f5576c;
                        box-shadow: 0 0 0 5px rgba(245,87,108,0.12);
                    }

            .unit-row {
                display: grid;
                grid-template-columns: 1fr auto 1fr;
                gap: 16px;
                align-items: end;
                margin-bottom: 24px;
            }

            .swap-btn {
                background: #f8f9ff;
                border: 2px solid #eee;
                border-radius: 50%;
                width: 54px;
                height: 54px;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                font-size: 20px;
                transition: all 0.3s;
                margin-bottom: 2px;
            }

                .swap-btn:hover {
                    background: #f5576c;
                    color: white;
                    border-color: #f5576c;
                    transform: rotate(180deg);
                }

            .calc-btn {
                width: 100%;
                height: 62px;
                background: linear-gradient( 135deg, #f093fb, #f5576c );
                color: white;
                border: none;
                border-radius: 18px;
                font-size: 18px;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.3s;
            }

                .calc-btn:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 12px 30px rgba(245,87,108,0.4);
                }

            /* Result */

            .result-box {
                background: linear-gradient( 135deg, #f093fb, #f5576c );
                border-radius: 22px;
                padding: 35px;
                text-align: center;
                margin-top: 30px;
                color: white;
                box-shadow: 0 12px 30px rgba(245,87,108,0.3);
            }

                .result-box .from-val {
                    font-size: 25px;
                    opacity: 1.85;
                    margin-bottom: 12px;
                }

                .result-box .to-val {
                    font-size: 54px;
                    font-weight: 800;
                    line-height: 1.2;
                }

                .result-box .unit-label {
                    font-size: 25px;
                    opacity: 1.8;
                    margin-top: 8px;
                }

            @@media(max-width:768px) {

                .container {
                    max-width: 100%;
                }

                .card {
                    padding: 50px 22px;
                }

                .card-header h1 {
                    font-size: 50px;
                }

                .category-tabs {
                    grid-template-columns: repeat(2, 1fr);
                }

                .unit-row {
                    grid-template-columns: 1fr;
                }

                .swap-btn {
                    margin: auto;
                }

                .result-box .to-val {
                    font-size: 50px;
                }
            }

    </style>
</head>
<body>
<div class="container">

    <a href="/" class="home-btn">← Home</a>

    <div class="card">
        <div class="card-header">
            <span class="icon">🔢</span>
            <h1>Unit Converter</h1>
            <p>Convert length, weight, temperature & volume</p>
        </div>

        <form method="post" action="/Unit/Convert">
            <input type="hidden" name="category" id="categoryInput" value="@(ViewBag.Category ?? "length")" />

            <!-- Category Tabs -->
            <div class="category-tabs">
                <button type="button" class="cat-btn @(ViewBag.Category == null || ViewBag.Category == "length" ? "active" : "")"
                        onclick="setCategory('length')">📏 Length</button>
                <button type="button" class="cat-btn @(ViewBag.Category == "weight" ? "active" : "")"
                        onclick="setCategory('weight')">⚖️ Weight</button>
                <button type="button" class="cat-btn @(ViewBag.Category == "temperature" ? "active" : "")"
                        onclick="setCategory('temperature')">🌡️ Temp</button>
                <button type="button" class="cat-btn @(ViewBag.Category == "volume" ? "active" : "")"
                        onclick="setCategory('volume')">🧪 Volume</button>
            </div>

            <div class="input-group">
                <label>Value</label>
                <input type="number" name="value" placeholder="Enter value"
                    value="@ViewBag.InputValue" step="any" required />
            </div>

            <div class="unit-row">
                <div class="input-group" style="margin-bottom:0;">
                    <label>From</label>
                    <select name="fromUnit" id="fromUnit">
                    </select>
                </div>
                <button type="button" class="swap-btn" onclick="swapUnits()">⇄</button>
                <div class="input-group" style="margin-bottom:0;">
                    <label>To</label>
                    <select name="toUnit" id="toUnit">
                    </select>
                </div>
            </div>

            <button type="submit" class="calc-btn">🔢 Convert</button>
        </form>

        @if (ViewBag.Result != null)
        {
            <div class="result-box">
                <div class="from-val">@ViewBag.Value @ViewBag.FromUnit =</div>
                <div class="to-val">@ViewBag.Result</div>
                <div class="unit-label">@ViewBag.ToUnit</div>
            </div>
        }
    </div>
</div>

<script>
    const units = {
        length: [
            { value: 'inch', label: 'Inch (in)' },
            { value: 'foot', label: 'Foot (ft)' },
            { value: 'yard', label: 'Yard (yd)' },
            { value: 'mile', label: 'Mile (mi)' },
            { value: 'cm', label: 'Centimeter (cm)' },
            { value: 'meter', label: 'Meter (m)' },
            { value: 'km', label: 'Kilometer (km)' }
        ],
        weight: [
            { value: 'pound', label: 'Pound (lb)' },
            { value: 'ounce', label: 'Ounce (oz)' },
            { value: 'ton_us', label: 'US Ton' },
            { value: 'kg', label: 'Kilogram (kg)' },
            { value: 'gram', label: 'Gram (g)' }
        ],
        temperature: [
            { value: 'fahrenheit', label: 'Fahrenheit (°F)' },
            { value: 'celsius', label: 'Celsius (°C)' },
            { value: 'kelvin', label: 'Kelvin (K)' }
        ],
        volume: [
            { value: 'gallon_us', label: 'US Gallon' },
            { value: 'quart', label: 'Quart (qt)' },
            { value: 'pint', label: 'Pint (pt)' },
            { value: 'cup', label: 'Cup' },
            { value: 'fl_oz', label: 'Fluid Ounce (fl oz)' },
            { value: 'liter', label: 'Liter (L)' },
            { value: 'ml', label: 'Milliliter (ml)' }
        ]
    };

    function populateUnits(category, selectedFrom, selectedTo) {
        const fromSel = document.getElementById('fromUnit');
        const toSel = document.getElementById('toUnit');
        fromSel.innerHTML = '';
        toSel.innerHTML = '';

        units[category].forEach((u, i) => {
            const opt1 = new Option(u.label, u.value);
            const opt2 = new Option(u.label, u.value);
            if (selectedFrom ? u.value === selectedFrom : i === 0) opt1.selected = true;
            if (selectedTo ? u.value === selectedTo : i === 1) opt2.selected = true;
            fromSel.appendChild(opt1);
            toSel.appendChild(opt2);
        });
    }

    function setCategory(cat) {
        document.getElementById('categoryInput').value = cat;
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        event.target.classList.add('active');
        populateUnits(cat);
    }

    function swapUnits() {
        const from = document.getElementById('fromUnit');
        const to = document.getElementById('toUnit');
        const temp = from.value;
        from.value = to.value;
        to.value = temp;
    }

    // Initialize
    const currentCat = document.getElementById('categoryInput').value || 'length';
    populateUnits(currentCat, '@ViewBag.FromUnit', '@ViewBag.ToUnit');
</script>
</body>
</html>