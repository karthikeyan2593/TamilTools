@{
    ViewData["Title"] = "Image to PDF - TamilTools";

    ViewData["Description"] = "Convert JPG, PNG, JPEG images into PDF online for free.";

    ViewData["Keywords"] = "image to pdf, jpg to pdf, png to pdf, pdf converter";
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Image to PDF</title>

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', Arial, sans-serif;
                background: linear-gradient(135deg,#f7971e 0%,#ffd200 100%);
                min-height: 100vh;
                padding: 30px 20px;
            }

            .container {
                max-width: 1100px;
                margin: 0 auto;
            }

            .card {
                background: white;
                border-radius: 24px;
                padding: 36px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.2);
                position: relative;
            }

            .home-btn {
                position: absolute;
                top: 20px;
                left: 20px;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: #f7971e;
                color: white;
                padding: 10px 16px;
                border-radius: 10px;
                text-decoration: none;
                font-weight: 600;
                font-size: 14px;
                box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            }

            .card-header {
                text-align: center;
                margin-bottom: 32px;
                margin-top: 30px;
            }

                .card-header .icon {
                    font-size: 48px;
                    margin-bottom: 12px;
                    display: block;
                }

                .card-header h1 {
                    font-size: 34px;
                    color: #1a1a2e;
                    font-weight: 800;
                    margin-bottom: 10px;
                }

                .card-header p {
                    color: #777;
                    font-size: 15px;
                }

            .upload-area {
                border: 2.5px dashed #f7971e;
                border-radius: 16px;
                padding: 50px 20px;
                text-align: center;
                cursor: pointer;
                transition: 0.3s;
                margin-bottom: 20px;
                background: #fffbf0;
            }

                .upload-area:hover {
                    background: #fff3d0;
                }

                .upload-area .upload-icon {
                    font-size: 54px;
                    margin-bottom: 14px;
                    display: block;
                }

                .upload-area strong {
                    color: #f7971e;
                    font-size: 22px;
                    display: block;
                    margin-bottom: 8px;
                }

                .upload-area p {
                    color: #777;
                    font-size: 15px;
                }

            #fileInput {
                display: none;
            }

            .preview-grid {
                display: grid;
                grid-template-columns: repeat(3,1fr);
                gap: 10px;
                margin-bottom: 20px;
            }

            .preview-item {
                border-radius: 10px;
                overflow: hidden;
                border: 2px solid #eee;
                aspect-ratio: 1;
            }

                .preview-item img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .file-count {
                text-align: center;
                color: #f7971e;
                font-weight: 700;
                font-size: 14px;
                margin-bottom: 16px;
            }

            .calc-btn {
                width: 100%;
                padding: 18px;
                background: linear-gradient(135deg,#f7971e,#ffd200);
                color: white;
                border: none;
                border-radius: 14px;
                font-size: 18px;
                font-weight: 700;
                cursor: pointer;
                transition: 0.3s;
            }

                .calc-btn:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 8px 25px rgba(247,151,30,0.4);
                }

            .error-box {
                background: #fff0f0;
                border: 2px solid #ffcccc;
                border-radius: 12px;
                padding: 16px;
                text-align: center;
                color: #e74c3c;
                font-weight: 600;
                margin-top: 16px;
            }

            .info-box {
                background: #fffbf0;
                border: 2px solid #ffe0a0;
                border-radius: 12px;
                padding: 16px;
                margin-top: 20px;
            }

                .info-box p {
                    font-size: 14px;
                    color: #555;
                    margin-bottom: 8px;
                    font-weight: 600;
                }

            .related-tools {
                margin-top: 40px;
            }

                .related-tools h2 {
                    text-align: center;
                    color: white;
                    margin-bottom: 24px;
                    font-size: 30px;
                    font-weight: 800;
                }

            .tools-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
                gap: 18px;
            }

            .tool-card {
                background: rgba(255,255,255,0.15);
                backdrop-filter: blur(10px);
                border-radius: 18px;
                padding: 24px;
                text-decoration: none;
                transition: 0.3s;
                border: 1px solid rgba(255,255,255,0.15);
            }

                .tool-card:hover {
                    transform: translateY(-5px);
                    background: rgba(255,255,255,0.22);
                }

            .tool-icon {
                font-size: 42px;
                margin-bottom: 14px;
            }

            .tool-card h3 {
                color: white;
                font-size: 18px;
                margin-bottom: 8px;
                font-weight: 700;
            }

            .tool-card p {
                color: rgba(255,255,255,0.85);
                font-size: 14px;
                line-height: 1.5;
            }

            @@media(max-width:768px) {

                .card {
                    padding: 24px;
                }

                .preview-grid {
                    grid-template-columns: repeat(2,1fr);
                }

                .card-header h1 {
                    font-size: 28px;
                }
            }

    </style>

</head>

<body>

    <div class="container">

        <div class="card">

            <a href="/"
                   class="home-btn">

                ← Home

            </a>

            <div class="card-header">

                <span class="icon">🖼️➡️📄</span>

                <h1>
                    Image to PDF
                </h1>

                <p>
                    Convert your images into PDF instantly
                </p>

            </div>

            <form method="post"
                  action="/Pdf/Convert"
                  enctype="multipart/form-data">

                <div class="upload-area"
                     onclick="document.getElementById('fileInput').click()">

                    <span class="upload-icon">📁</span>

                    <strong>
                        Select Images
                    </strong>

                    <p>
                        JPG, PNG, JPEG — Multiple images supported
                    </p>

                </div>

                <input type="file"
                       id="fileInput"
                       name="images"
                       accept="image/*"
                       multiple
                       onchange="previewImages(this)" />

                <div id="previewGrid"
                     class="preview-grid"
                     style="display:none;">
                </div>

                <div id="fileCount"
                     class="file-count"
                     style="display:none;">
                </div>

                <button type="submit"
                        class="calc-btn">

                    📄 Convert to PDF

                </button>

            </form>

            @if (ViewBag.Error != null)
            {
                <div class="error-box">
                    ⚠️ @ViewBag.Error
                </div>
            }

            <div class="info-box">

                <p>✅ Combine multiple images into one PDF</p>

                <p>✅ Auto fit to A4 page size</p>

                <p>✅ Completely Free Tool</p>

            </div>

        </div>

        <div class="related-tools">

            <h2>
                🔥 Related Tools
            </h2>

            <div class="tools-grid">

                <a href="/Pdf/Merge"
                       class="tool-card">

                    <div class="tool-icon">📄</div>

                    <h3>Merge PDF</h3>

                    <p>
                        Combine multiple PDF files into one
                    </p>

                </a>

                <a href="/Pdf/Compress"
                       class="tool-card">

                    <div class="tool-icon">🗜️</div>

                    <h3>Compress PDF</h3>

                    <p>
                        Reduce PDF file size online
                    </p>

                </a>

                <a href="/Pdf/PdfToImage"
                       class="tool-card">

                    <div class="tool-icon">🖼️</div>

                    <h3>PDF to Image</h3>

                    <p>
                        Convert PDF pages into images
                    </p>

                </a>

                <a href="/Image/JpgToPng"
                       class="tool-card">

                    <div class="tool-icon">🔄</div>

                    <h3>JPG to PNG</h3>

                    <p>
                        Convert JPG images into PNG
                    </p>

                </a>

                <a href="/Image/Resize"
                       class="tool-card">

                    <div class="tool-icon">📐</div>

                    <h3>Resize Image</h3>

                    <p>
                        Resize images easily online
                    </p>

                </a>

                <a href="/Image/Crop"
                       class="tool-card">

                    <div class="tool-icon">✂️</div>

                    <h3>Crop Image</h3>

                    <p>
                        Crop and edit images instantly
                    </p>

                </a>

            </div>

        </div>

    </div>

    <script>

            function previewImages(input) {

                const grid = document.getElementById('previewGrid');
                const count = document.getElementById('fileCount');

                grid.innerHTML = '';

                if (input.files && input.files.length > 0) {

                    grid.style.display = 'grid';
                    count.style.display = 'block';

                    count.innerText =
                        input.files.length + ' images selected';

                    Array.from(input.files)
                        .slice(0, 6)
                        .forEach(file => {

                            const reader = new FileReader();

                            reader.onload = e => {

                                const div = document.createElement('div');

                                div.className = 'preview-item';

                                div.innerHTML =
                                    '<img src="' + e.target.result + '" />';

                                grid.appendChild(div);
                            };

                            reader.readAsDataURL(file);
                        });
                }
            }

    </script>

</body>

</html>