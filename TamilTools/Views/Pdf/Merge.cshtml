@{
    ViewData["Title"] = "Merge PDF - TamilTools";

    ViewData["Description"] = "Merge multiple PDF files into one PDF online for free.";

    ViewData["Keywords"] = "merge pdf, combine pdf, pdf merger online";
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Merge PDF</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: linear-gradient(135deg, #101727, #23395d);
                min-height: 100vh;
                padding: 40px 20px;
                color: white;
            }

            .container {
                max-width: 1200px;
                margin: auto;
            }

            .card {
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 28px;
                padding: 40px;
                backdrop-filter: blur(10px);
                box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            }

            .top-bar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 30px;
            }

            .home-btn {
                background: #4f7cff;
                color: white;
                text-decoration: none;
                padding: 12px 18px;
                border-radius: 12px;
                font-weight: 700;
                transition: 0.3s;
            }

                .home-btn:hover {
                    background: #3d67df;
                }

            .header {
                text-align: center;
                margin-bottom: 40px;
            }

                .header .icon {
                    font-size: 70px;
                    margin-bottom: 20px;
                }

                .header h1 {
                    font-size: 52px;
                    margin-bottom: 15px;
                }

                .header p {
                    font-size: 22px;
                    color: #c7d3ea;
                }

            .features {
                display: flex;
                justify-content: center;
                gap: 30px;
                margin-top: 20px;
                flex-wrap: wrap;
            }

                .features span {
                    color: #6fff95;
                    font-weight: 700;
                }

            .upload-area {
                border: 3px dashed rgba(255,255,255,0.4);
                border-radius: 24px;
                padding: 40px;
                min-height: 300px;
                transition: 0.3s;
            }

                .upload-area.dragover {
                    background: rgba(255,255,255,0.05);
                    border-color: #6fff95;
                }

            .upload-center {
                text-align: center;
                margin-bottom: 30px;
            }

                .upload-center i {
                    font-size: 70px;
                    margin-bottom: 20px;
                    color: #ffd34d;
                }

                .upload-center h2 {
                    font-size: 32px;
                    margin-bottom: 10px;
                }

                .upload-center p {
                    color: #c8d1e3;
                    margin-bottom: 25px;
                }

            .upload-btn {
                background: linear-gradient(135deg, #4f7cff, #2446a8);
                color: white;
                border: none;
                padding: 16px 26px;
                border-radius: 14px;
                font-size: 18px;
                font-weight: 700;
                cursor: pointer;
            }

            .file-preview {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 20px;
                margin-top: 30px;
            }

            .file-card {
                background: rgba(255,255,255,0.07);
                border-radius: 20px;
                padding: 20px;
                position: relative;
                text-align: center;
                border: 1px solid rgba(255,255,255,0.08);
            }

                .file-card i {
                    font-size: 70px;
                    color: #ff5757;
                    margin-bottom: 15px;
                }

            .file-name {
                word-break: break-word;
                font-weight: 600;
                margin-bottom: 10px;
            }

            .remove-btn {
                position: absolute;
                top: 12px;
                right: 12px;
                width: 34px;
                height: 34px;
                border: none;
                border-radius: 50%;
                background: #ff4c4c;
                color: white;
                cursor: pointer;
                font-size: 16px;
            }

            .merge-btn {
                width: 100%;
                margin-top: 35px;
                background: linear-gradient(135deg, #ff9800, #ffcc00);
                border: none;
                padding: 22px;
                border-radius: 18px;
                color: white;
                font-size: 24px;
                font-weight: 800;
                cursor: pointer;
                transition: 0.3s;
            }

                .merge-btn:hover {
                    transform: translateY(-2px);
                }

            .tools-section {
                margin-top: 50px;
            }

            .tools-title {
                text-align: center;
                font-size: 32px;
                margin-bottom: 30px;
            }

            .tools-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 20px;
            }

            .tool-card {
                background: rgba(255,255,255,0.06);
                border-radius: 20px;
                padding: 24px;
                text-decoration: none;
                color: white;
                transition: 0.3s;
                border: 1px solid rgba(255,255,255,0.08);
            }

                .tool-card:hover {
                    transform: translateY(-5px);
                    background: rgba(255,255,255,0.1);
                }

                .tool-card i {
                    font-size: 42px;
                    margin-bottom: 15px;
                    color: #ffd34d;
                }

                .tool-card h3 {
                    margin-bottom: 10px;
                }

                .tool-card p {
                    color: #c8d1e3;
                    font-size: 15px;
                }

            .seo-section {
                margin-top: 50px;
                background: rgba(255,255,255,0.05);
                padding: 30px;
                border-radius: 20px;
                line-height: 1.8;
                border: 1px solid rgba(255,255,255,0.08);
            }

                .seo-section h2,
                .seo-section h3 {
                    margin-bottom: 15px;
                    color: white;
                }

                .seo-section p,
                .seo-section li {
                    color: #d6deef;
                }

            @@media(max-width:768px) {

                .header h1 {
                    font-size: 36px;
                }

                .header p {
                    font-size: 18px;
                }

                .card {
                    padding: 20px;
                }
            }

    </style>

</head>

<body>

    <div class="container">

        <div class="card">

            <div class="top-bar">

                <a href="/"
                       class="home-btn">
                    ← Home
                </a>

            </div>

            <div class="header">

                <div class="icon">📄</div>

                <h1>Merge PDF</h1>

                <p>
                    Combine multiple PDF files into a single PDF quickly and easily
                </p>

                <div class="features">
                    <span>✔ Free</span>
                    <span>✔ Online</span>
                    <span>✔ No Limits</span>
                    <span>✔ Secure</span>
                </div>

            </div>

            <div class="upload-area"
                 id="uploadArea">

                <div class="upload-center">

                    <i class="fa-solid fa-folder-open"></i>

                    <h2>Select PDF Files</h2>

                    <p>
                        Upload multiple PDF files or drag and drop here
                    </p>

                    <button class="upload-btn"
                            onclick="document.getElementById('pdfInput').click()">

                        Choose PDF Files

                    </button>

                    <input type="file"
                           id="pdfInput"
                           accept=".pdf"
                           multiple
                           hidden />

                </div>

                <div class="file-preview"
                     id="filePreview">
                </div>

            </div>

            <button class="merge-btn">
                🔗 Merge PDF
            </button>

            <div class="tools-section">

                <h2 class="tools-title">
                    🔥 Related PDF Tools
                </h2>

                <div class="tools-grid">

                    <a href="/Pdf/Index"
                           class="tool-card">

                        <i class="fa-solid fa-image"></i>

                        <h3>Image to PDF</h3>

                        <p>
                            Convert images into PDF instantly.
                        </p>

                    </a>

                    <a href="#"
                           class="tool-card">

                        <i class="fa-solid fa-compress"></i>

                        <h3>Compress PDF</h3>

                        <p>
                            Reduce PDF file size online.
                        </p>

                    </a>

                    <a href="#"
                           class="tool-card">

                        <i class="fa-solid fa-file-export"></i>

                        <h3>PDF to Image</h3>

                        <p>
                            Convert PDF pages into images.
                        </p>

                    </a>

                    <a href="#"
                           class="tool-card">

                        <i class="fa-solid fa-file-word"></i>

                        <h3>PDF to Word</h3>

                        <p>
                            Convert PDF into editable Word files.
                        </p>

                    </a>

                </div>

            </div>

            <div class="seo-section">

                <h2>
                    Free Merge PDF Tool Online
                </h2>

                <p>
                    Merge multiple PDF files into one PDF document easily using TamilTools.
                    This free online PDF merger helps you combine PDFs securely without installing software.
                </p>

                <h3>
                    Features
                </h3>

                <ul>
                    <li>Combine unlimited PDF files</li>
                    <li>Fast and secure merging</li>
                    <li>No watermark</li>
                    <li>Works on mobile and desktop</li>
                </ul>

            </div>

        </div>

    </div>

    <script>

            const pdfInput =
                document.getElementById('pdfInput');

            const filePreview =
                document.getElementById('filePreview');

            const uploadArea =
                document.getElementById('uploadArea');

            let selectedFiles = [];

            pdfInput.addEventListener('change', function (e) {

                addFiles(e.target.files);
            });

            uploadArea.addEventListener('dragover', function (e) {

                e.preventDefault();

                uploadArea.classList.add('dragover');
            });

            uploadArea.addEventListener('dragleave', function () {

                uploadArea.classList.remove('dragover');
            });

            uploadArea.addEventListener('drop', function (e) {

                e.preventDefault();

                uploadArea.classList.remove('dragover');

                addFiles(e.dataTransfer.files);
            });

            function addFiles(files) {

                Array.from(files).forEach(file => {

                    if (file.type === 'application/pdf') {

                        selectedFiles.push(file);
                    }
                });

                renderFiles();
            }

            function renderFiles() {

                filePreview.innerHTML = '';

                selectedFiles.forEach((file, index) => {

                    const card = document.createElement('div');

                    card.className = 'file-card';

                    card.innerHTML = `

                        <button class="remove-btn"
                                onclick="removeFile(${index})">
                            ×
                        </button>

                        <i class="fa-solid fa-file-pdf"></i>

                        <div class="file-name">
                            ${file.name}
                        </div>

                        <div>
                            ${(file.size / 1024 / 1024).toFixed(2)} MB
                        </div>
                    `;

                    filePreview.appendChild(card);
                });
            }

            function removeFile(index) {

                selectedFiles.splice(index, 1);

                renderFiles();
            }

    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>

    <script>

        const mergeBtn =
        document.querySelector('.merge-btn');

        mergeBtn.addEventListener('click', mergePDFs);

        async function mergePDFs() {

        if (selectedFiles.length < 2) {

        alert('Please select at least 2 PDF files');

        return;
        }

        mergeBtn.innerHTML =
        'Merging PDFs...';

        mergeBtn.disabled = true;

        const mergedPdf =
        await PDFLib.PDFDocument.create();

        for (const file of selectedFiles) {

        const bytes =
        await file.arrayBuffer();

        const pdf =
        await PDFLib.PDFDocument.load(bytes);

        const copiedPages =
        await mergedPdf.copyPages(
        pdf,
        pdf.getPageIndices()
        );

        copiedPages.forEach(page => {

        mergedPdf.addPage(page);
        });
        }

        const mergedBytes =
        await mergedPdf.save();

        const blob =
        new Blob(
        [mergedBytes],
        { type: 'application/pdf' }
        );

        const url =
        URL.createObjectURL(blob);

        const a =
        document.createElement('a');

        a.href = url;

        a.download = 'TamilTools-Merged.pdf';

        a.click();

        URL.revokeObjectURL(url);

        mergeBtn.innerHTML =
        '✅ Downloaded';

        setTimeout(() => {

        mergeBtn.innerHTML =
        '🔗 Merge PDF';

        mergeBtn.disabled = false;

        }, 2000);
        }

    </script>

</body>

</html>