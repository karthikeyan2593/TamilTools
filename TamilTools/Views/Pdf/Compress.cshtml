@{
    ViewData["Title"] = "Compress PDF - TamilTools";

    ViewData["Description"] =
        "Compress PDF files online for free.";

    ViewData["Keywords"] =
        "compress pdf, reduce pdf size, pdf compressor";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg,#0f172a,#1e3a8a);
        font-family: 'Segoe UI', sans-serif;
    }

    .compress-wrapper {
        max-width: 950px;
        margin: 40px auto;
        padding: 20px;
    }

    .compress-card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(12px);
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.35);
        color: white;
    }

    .home-btn {
        background: linear-gradient(135deg,#3b82f6,#2563eb);
        color: white;
        text-decoration: none;
        padding: 14px 22px;
        border-radius: 14px;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 30px;
        transition: 0.3s;
    }

        .home-btn:hover {
            transform: translateY(-2px);
        }

    .compress-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .compress-header i {
            font-size: 80px;
            color: #60a5fa;
            margin-bottom: 20px;
        }

        .compress-header h1 {
            font-size: 52px;
            margin-bottom: 15px;
        }

        .compress-header p {
            color: #cbd5e1;
            font-size: 20px;
        }

    .upload-box {
        border: 3px dashed rgba(255,255,255,0.2);
        border-radius: 24px;
        padding: 40px;
        text-align: center;
        margin-bottom: 30px;
        transition: 0.3s;
    }

        .upload-box:hover {
            border-color: #60a5fa;
            background: rgba(255,255,255,0.03);
        }

        .upload-box i {
            font-size: 70px;
            color: #60a5fa;
            margin-bottom: 20px;
        }

        .upload-box h2 {
            font-size: 34px;
            margin-bottom: 10px;
        }

        .upload-box p {
            color: #cbd5e1;
            margin-bottom: 25px;
        }

    .upload-btn {
        background: linear-gradient(135deg,#3b82f6,#2563eb);
        border: none;
        color: white;
        padding: 16px 28px;
        border-radius: 16px;
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
    }

        .upload-btn:hover {
            transform: translateY(-2px);
        }

    #pdfInput {
        display: none;
    }

    .file-preview {
        background: rgba(255,255,255,0.05);
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 30px;
        display: none;
    }

        .file-preview.active {
            display: block;
        }

        .file-preview h3 {
            margin-bottom: 15px;
            font-size: 24px;
        }

    .file-item {
        display: flex;
        align-items: center;
        gap: 15px;
        background: rgba(255,255,255,0.05);
        padding: 18px;
        border-radius: 16px;
    }

        .file-item i {
            font-size: 42px;
            color: #ff5c5c;
        }

    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 25px;
        margin-bottom: 30px;
    }

    .setting-card {
        background: rgba(255,255,255,0.05);
        border-radius: 20px;
        padding: 25px;
    }

        .setting-card label {
            display: block;
            margin-bottom: 12px;
            font-weight: 700;
            font-size: 16px;
        }

    select,
    input[type="range"] {
        width: 100%;
    }

    select {
        padding: 14px;
        border-radius: 14px;
        border: none;
        background: rgba(255,255,255,0.1);
        color: white;
        font-size: 16px;
    }

    .range-value {
        margin-top: 12px;
        font-size: 18px;
        font-weight: 700;
        color: #60a5fa;
    }

    .compress-btn {
        width: 100%;
        background: linear-gradient(135deg,#f59e0b,#facc15);
        border: none;
        padding: 22px;
        border-radius: 18px;
        color: white;
        font-size: 24px;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
    }

        .compress-btn:hover {
            transform: translateY(-2px);
        }

    .features {
        margin-top: 35px;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 20px;
    }

    .feature {
        background: rgba(255,255,255,0.05);
        border-radius: 18px;
        padding: 20px;
    }

        .feature h4 {
            margin-bottom: 10px;
            font-size: 18px;
        }

        .feature p {
            color: #cbd5e1;
            line-height: 1.6;
        }

    @@media (max-width: 768px) {

        .compress-header h1 {
            font-size: 38px;
        }

        .compress-card {
            padding: 20px;
        }

        .upload-box {
            padding: 25px;
        }

        .compress-btn {
            font-size: 20px;
            padding: 18px;
        }
    }

</style>

<div class="compress-wrapper">

    <div class="compress-card">

        <a href="/"
               class="home-btn">

            ← Home

        </a>

        <div class="compress-header">

            <i class="fa-solid fa-file-zipper"></i>

            <h1>Compress PDF</h1>

            <p>
                Reduce PDF size with premium compression
            </p>

        </div>

        <form method="post"
              enctype="multipart/form-data"
              action="/Pdf/Compress">

            <div class="upload-box">

                <i class="fa-solid fa-file-pdf"></i>

                <h2>Select PDF File</h2>

                <p>
                    Upload your PDF file to compress instantly
                </p>

                <button type="button"
                        class="upload-btn"
                        onclick="document.getElementById('pdfInput').click()">

                    Choose PDF File

                </button>

                <input type="file"
                       id="pdfInput"
                       name="pdfFile"
                       accept=".pdf">

            </div>

            <div class="file-preview"
                 id="filePreview">

                <h3>
                    Selected File
                </h3>

                <div class="file-item">

                    <i class="fa-solid fa-file-pdf"></i>

                    <div>

                        <div id="fileName">
                            No file selected
                        </div>

                        <div id="fileSize">
                        </div>

                    </div>

                </div>

            </div>

            <div class="settings-grid">

                <div class="setting-card">

                    <label>
                        Compression Level
                    </label>

                    <select>

                        <option>
                            Low Compression
                        </option>

                        <option selected>
                            Medium Compression
                        </option>

                        <option>
                            High Compression
                        </option>

                    </select>

                </div>

                <div class="setting-card">

                    <label>
                        Image Quality
                    </label>

                    <input type="range"
                           min="10"
                           max="100"
                           value="75"
                           id="qualityRange">

                    <div class="range-value"
                         id="qualityText">

                        75%

                    </div>

                </div>

            </div>

            <button type="submit"
                    class="compress-btn">

                🚀 Compress PDF

            </button>

        </form>

        <div class="features">

            <div class="feature">

                <h4>
                    ⚡ Fast Compression
                </h4>

                <p>
                    Compress PDF files quickly without waiting.
                </p>

            </div>

            <div class="feature">

                <h4>
                    🔒 Secure Processing
                </h4>

                <p>
                    Files stay private and secure during compression.
                </p>

            </div>

            <div class="feature">

                <h4>
                    📱 Mobile Friendly
                </h4>

                <p>
                    Works perfectly on desktop and mobile devices.
                </p>

            </div>

        </div>

    </div>

</div>

<script>

    async function compressPDF() {

        const fileInput =
            document.getElementById("pdfFile");

        if (fileInput.files.length === 0) {

            alert("Select PDF file");
            return;
        }

        try {

            const file =
                fileInput.files[0];

            const arrayBuffer =
                await file.arrayBuffer();

            const pdfDoc =
                await PDFLib.PDFDocument.load(arrayBuffer);

            const pdfBytes =
                await pdfDoc.save({
                    useObjectStreams: true
                });

            const blob =
                new Blob(
                    [pdfBytes],
                    { type: "application/pdf" }
                );

            const url =
                URL.createObjectURL(blob);

            const a =
                document.createElement("a");

            a.href = url;

            a.download =
                "compressed-" +
                Date.now() +
                ".pdf";

            document.body.appendChild(a);

            a.click();

            document.body.removeChild(a);

            setTimeout(() => {

                URL.revokeObjectURL(url);

            }, 1000);

            fileInput.value = "";

            alert("PDF compressed successfully!");

        }
        catch (error) {

            console.error(error);

            alert("Compression failed");

        }
    }

</script>