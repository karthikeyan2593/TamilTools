@model TamilTools.Models.SipCalculatorViewModel

@{
    ViewData["Title"] = "SIP Calculator - TamilTools";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

    * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    }

    body {
    font-family: 'Segoe UI', sans-serif;
    background: radial-gradient(circle at top left, #1f1f3d 0%, transparent 30%), radial-gradient(circle at bottom right, #16213e 0%, transparent 30%), linear-gradient(135deg, #0d0d1a 0%, #12122a 100%);
    color: white;
    min-height: 100vh;
    padding: 30px 15px;
    }

    .container {
    max-width: 1100px;
    margin: auto;
    }

    .top-bar {
    margin-bottom: 25px;
    }

    .home-btn {
    display: inline-block;
    text-decoration: none;
    color: white;
    background: rgba(255,255,255,0.08);
    padding: 12px 18px;
    border-radius: 14px;
    transition: 0.3s ease;
    border: 1px solid rgba(255,255,255,0.08);
    }

    .home-btn:hover {
    background: rgba(255,255,255,0.15);
    transform: translateY(-2px);
    }

    .calculator-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 28px;
    padding: 40px;
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.35);
    }

    .title {
    text-align: center;
    margin-bottom: 35px;
    }

    .title h1 {
    font-size: 42px;
    margin-bottom: 10px;
    }

    .title p {
    color: rgba(255,255,255,0.7);
    }

    .form-group {
    margin-bottom: 22px;
    }

    .form-group label {
    display: block;
    margin-bottom: 10px;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    }

    .form-control {
    width: 100%;
    padding: 16px;
    border-radius: 14px;
    border: 2px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
    color: white;
    font-size: 16px;
    transition: 0.3s ease;
    }

    .form-control::placeholder {
    color: rgba(255,255,255,0.4);
    }

    .form-control:focus {
    outline: none;
    border-color: #22c55e;
    box-shadow: 0 0 18px rgba(34,197,94,0.25);
    }

    .calculate-btn {
    width: 100%;
    border: none;
    padding: 16px;
    border-radius: 16px;
    font-size: 17px;
    font-weight: bold;
    color: white;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    cursor: pointer;
    transition: 0.3s ease;
    }

    .calculate-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 24px rgba(34,197,94,0.3);
    }

    .summary-section {
    margin-top: 50px;
    }

    .summary-title {
    text-align: center;
    font-size: 34px;
    margin-bottom: 35px;
    }

    .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
    gap: 20px;
    }

    .summary-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 22px;
    padding: 30px;
    text-align: center;
    transition: 0.3s ease;
    }

    .summary-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 24px rgba(0,0,0,0.3);
    }

    .summary-card h5 {
    color: rgba(255,255,255,0.65);
    margin-bottom: 12px;
    }

    .summary-card h2 {
    font-size: 34px;
    }

    .invested {
    color: #3b82f6;
    }

    .returns {
    color: #22c55e;
    }

    .total {
    color: #f59e0b;
    }

    .chart-container {
    max-width: 420px;
    margin: 50px auto 0;
    }

    .seo-section {
    margin-top: 50px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 24px;
    padding: 35px;
    line-height: 1.8;
    color: rgba(255,255,255,0.75);
    }

    .seo-section h2 {
    margin-bottom: 15px;
    color: white;
    }

    .seo-section p {
    margin-bottom: 15px;
    }

    @@media(max-width:768px) {

    .calculator-card {
    padding: 25px;
    }

    .title h1 {
    font-size: 32px;
    }
    }

</style>

<div class="container">

    <div class="top-bar">

        <a href="/"
               class="home-btn">

            ← Home

        </a>

    </div>

    <div class="calculator-card">

        <div class="title">

            <h1>
                💰 SIP Calculator
            </h1>

            <p>
                Calculate your SIP investment returns instantly.
            </p>

        </div>

        <form method="post">

            <div class="form-group">

                <label>
                    Monthly Investment (₹)
                </label>

                <input type="number"
                       asp-for="MonthlyInvestment"
                       value="@(Model.MonthlyInvestment == 0 ? "" : Model.MonthlyInvestment)"
                       class="form-control"
                       placeholder="Enter monthly investment"
                       required />

            </div>

            <div class="form-group">

                <label>
                    Expected Return Rate (%)
                </label>

                <input type="number"
                       step="0.1"
                       asp-for="ExpectedReturnRate"
                       value="@(Model.ExpectedReturnRate == 0 ? "" : Model.ExpectedReturnRate)"
                       class="form-control"
                       placeholder="Expected annual return"
                       required />

            </div>

            <div class="form-group">

                <label>
                    Investment Period (Years)
                </label>

                <input type="number"
                       asp-for="Years"
                       value="@(Model.Years == 0 ? "" : Model.Years)"
                       class="form-control"
                       placeholder="Investment duration"
                       required />

            </div>

            <button type="submit"
                    class="calculate-btn">

                Calculate SIP Returns

            </button>

        </form>

        @if (Model.TotalValue > 0)
        {
            <div class="summary-section">

                <h2 class="summary-title">

                    Investment Summary

                </h2>

                <div class="summary-grid">

                    <div class="summary-card">

                        <h5>
                            Invested Amount
                        </h5>

                        <h2 class="invested">

                            ₹@Model.InvestedAmount.ToString("N0")

                        </h2>

                    </div>

                    <div class="summary-card">

                        <h5>
                            Estimated Returns
                        </h5>

                        <h2 class="returns">

                            ₹@Model.EstimatedReturns.ToString("N0")

                        </h2>

                    </div>

                    <div class="summary-card">

                        <h5>
                            Total Value
                        </h5>

                        <h2 class="total">

                            ₹@Model.TotalValue.ToString("N0")

                        </h2>

                    </div>

                </div>

                <div class="chart-container">

                    <canvas id="sipChart"></canvas>

                </div>

            </div>
        }

    </div>

    <div class="seo-section">

        <h2>
            What is SIP?
        </h2>

        <p>
            SIP (Systematic Investment Plan) helps investors invest fixed amounts regularly in mutual funds and build long-term wealth through compounding.
        </p>

        <h2>
            Why use SIP Calculator?
        </h2>

        <p>
            SIP Calculator helps estimate future investment value, expected returns and total invested amount instantly.
        </p>

    </div>

</div>

@if (Model.TotalValue > 0)
{
    <script>

        const ctx =
        document.getElementById('sipChart');

        new Chart(ctx, {

        type: 'doughnut',

        data: {

        labels: [
        'Invested Amount',
        'Estimated Returns'
        ],

        datasets: [{

        data: [
        @Model.InvestedAmount,
        @Model.EstimatedReturns
        ],

        backgroundColor: [
        '#3b82f6',
        '#22c55e'
        ],

        borderWidth: 0

        }]
        },

        options: {

        responsive: true,

        plugins: {

        legend: {

        labels: {

        color: 'white'
        }

        }

        }

        }

        });

    </script>
}