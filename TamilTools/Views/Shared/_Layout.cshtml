<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TamilTools</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TamilTools.styles.css" asp-append-version="true" />

    <meta name="google-adsense-account" content="ca-pub-6802993501474177">
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">TamilTools</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">

            <!-- 🔥 Banner Ad (Top) -->
            <div style="text-align:center; margin-bottom:15px;">
                <script>
                                    atOptions = {
                                      'key' : '122e16a3651db05d45c38c6c76ff6905',
                                      'format' : 'iframe',
                                      'height' : 250,
                                      'width' : 300,
                                      'params' : {}
                                    };
                </script>
                <script src="https://www.highperformanceformat.com/122e16a3651db05d45c38c6c76ff6905/invoke.js"></script>
            </div>

            @RenderBody()

            <!-- 🔥 Banner Ad (Bottom) -->
            <div style="text-align:center; margin-top:15px;">
                <script>
                    atOptions = {
                    'key' : '122e16a3651db05d45c38c6c76ff6905',
                    'format' : 'iframe',
                    'height' : 250,
                    'width' : 300,
                    'params' : {}
                    };
                </script>
                <script src="https://www.highperformanceformat.com/122e16a3651db05d45c38c6c76ff6905/invoke.js"></script>
            </div>

        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - TamilTools -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- JS Files -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- 🔥 Popunder Ad -->
    <script src="https://pl29336317.profitablecpmratenetwork.com/22/ae/cc/22aecc62df48701dd39fef7fde6e7cc9.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>