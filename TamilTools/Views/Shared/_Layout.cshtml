<!DOCTYPE html>
<html lang="en">


<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="tbIoct1pg6pvYDoQ8iKz6L28OYNqr_7_wDsFDflOryQ" />

    <title>@ViewData["Title"] - TamilTools</title>

    <meta name="description" content="@(ViewData["Description"] ?? "TamilTools - Free Online Tools in Tamil. EMI Calculator, Salary Calculator, Currency Converter and more!")" />
    <meta name="keywords" content="@(ViewData["Keywords"] ?? "tamil tools, free online tools, EMI calculator tamil, salary calculator tamil")" />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content="@ViewData["Title"] - TamilTools" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "Free Online Tools in Tamil")" />
    <meta property="og:url" content="https://tamiltools.co.in" />
    <meta property="og:type" content="website" />

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TamilTools.styles.css" asp-append-version="true" />

    <!-- Adsense -->
    <meta name="google-adsense-account" content="ca-pub-6802993501474177">

    <script async
            src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6802993501474177"
            crossorigin="anonymous">
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XCQTHFZB29"></script>

    <script>
        window.dataLayer = window.dataLayer || [];

        function gtag() {
        dataLayer.push(arguments);
        }

        gtag('js', new Date());
        gtag('config', 'G-XCQTHFZB29');
    </script>

    <!-- Adsterra Social Bar -->
    <script src="https://pl29438967.profitablecpmratenetwork.com/8c/01/55/8c015550bd97dbac7d4620f3bf992356.js"></script>
    @RenderSection("Head", required: false)
</head>

<body>



    <div class="container">

        <main role="main" class="pb-3">

            <!-- Top Banner Ad -->
            

            @RenderBody()

            <!-- Bottom Banner Ad -->
            <div style="text-align:center; margin-top:15px;">

                <script>
                    atOptions = {
                    'key': '122e16a3651db05d45c38c6c76ff6905',
                    'format': 'iframe',
                    'height': 250,
                    'width': 300,
                    'params': {}
                    };
                </script>

                <script src="https://www.highperformanceformat.com/122e16a3651db05d45c38c6c76ff6905/invoke.js"></script>

            </div>

        </main>

    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- A-ADS Ad Unit -->
    <!-- BEGIN AADS AD UNIT 2437849 -->
    <div id="frame" style="width: 100%;margin: auto;position: relative; z-index: 99998;">
        <iframe data-aa='2437849' src='//acceptable.a-ads.com/2437849/?size=Adaptive'
                style='border:0; padding:0; width:70%; height:auto; overflow:hidden;display: block;margin: auto'></iframe>
    </div>
    <!-- END AADS AD UNIT 2437849 -->

    <footer class="border-top footer text-muted">

        <div class="container">
            &copy; 2026 - TamilTools -
            <a asp-controller="Home"
                   asp-action="Privacy">
                Privacy
            </a>
        </div>

    </footer>

    <!-- JS Files -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Adsterra Popunder -->
    

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>