@{
    ViewData["Title"] = "நாணய மாற்றி - Currency Converter Tamil";
    ViewData["Description"] = "உலக நாணயங்களை தமிழில் மாற்றுங்கள். INR to USD, AED, SGD live exchange rates.";
    ViewData["Keywords"] = "currency converter tamil, நாணய மாற்றி, INR to USD tamil, exchange rate tamil";
}

<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Currency Converter</title>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            padding: 30px 20px;
        }

        .container { max-width: 520px; margin: 0 auto; }

        .lang-toggle {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 16px;
        }

        .lang-btn {
            background: rgba(255,255,255,0.1);
            border-radius: 50px;
            padding: 5px;
            display: flex;
            gap: 4px;
        }

        .lang-option {
            padding: 7px 18px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            background: transparent;
            color: rgba(255,255,255,0.5);
            transition: all 0.3s;
        }

        .lang-option.active { background: white; color: #1a1a2e; }

        .card {
            background: #0f3460;
            border-radius: 24px;
            padding: 36px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.1);
            position: relative;
        }

        .home-btn {
            position: absolute;
            top: 20px;
            left: 20px;

            display: inline-flex;
            align-items: center;
            gap: 8px;

            background: #0f9d94;
            color: white;

            padding: 10px 16px;
            border-radius: 10px;

            text-decoration: none;
            font-weight: 600;
            font-size: 14px;

            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

        .card-header {
            text-align: center;
            margin-bottom: 32px;
            margin-top: 30px;
        }

        .card-header .icon { font-size: 48px; margin-bottom: 12px; display: block; }
        .card-header h1 { font-size: 26px; color: white; font-weight: 800; margin-bottom: 6px; }
        .card-header p { color: rgba(255,255,255,0.5); font-size: 14px; }

        .input-group { margin-bottom: 20px; }

        .input-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: rgba(255,255,255,0.7);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-group input,
        .input-group select {
            width: 100%;
            padding: 14px;
            border: 2px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            font-size: 16px;
            transition: all 0.3s;
            color: white;
            font-weight: 600;
            background: rgba(255,255,255,0.05);
        }

        .input-group input:focus,
        .input-group select:focus {
            outline: none;
            border-color: #e94560;
            box-shadow: 0 0 0 4px rgba(233,69,96,0.2);
        }

        .input-group select option { background: #0f3460; color: white; }

        .currency-row {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 12px;
            align-items: end;
            margin-bottom: 20px;
        }

        .swap-btn {
            background: rgba(255,255,255,0.1);
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 50%;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 18px;
            transition: all 0.3s;
            color: white;
            margin-bottom: 2px;
        }

        .swap-btn:hover { background: #e94560; border-color: #e94560; }

        .calc-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #e94560, #f5576c);
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
        }

        .calc-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(233,69,96,0.4);
        }

        .result-box {
            background: linear-gradient(135deg, #e94560, #f5576c);
            border-radius: 16px;
            padding: 24px;
            text-align: center;
            margin-top: 24px;
        }

        .result-box .from-amount {
            font-size: 14px;
            color: rgba(255,255,255,0.8);
            margin-bottom: 8px;
        }

        .result-box .to-amount {
            font-size: 40px;
            font-weight: 800;
            color: white;
            margin-bottom: 8px;
        }

        .result-box .rate-info {
            font-size: 13px;
            color: rgba(255,255,255,0.7);
        }

        .error-box {
            background: rgba(231,76,60,0.2);
            border: 2px solid rgba(231,76,60,0.5);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
            color: #e74c3c;
            font-weight: 600;
            margin-top: 16px;
        }
    </style>
</head>

<body>

<div class="container">

    <div class="lang-toggle">
        <div class="lang-btn">
            <button class="lang-option active" onclick="setLang('ta')" id="btn-ta">தமிழ்</button>
            <button class="lang-option" onclick="setLang('en')" id="btn-en">English</button>
        </div>
    </div>

    <div class="card">

        <a href="/" class="home-btn">
            ← Home
        </a>

        <div class="card-header">
            <span class="icon">💱</span>
            <h1 id="title">நாணய மாற்றி</h1>
            <p id="subtitle">உலக நாணயங்களை உடனே மாற்றுங்கள்</p>
        </div>

        <form method="post" action="/Currency/Convert">
            <div class="input-group">
                <label id="label1">தொகை</label>
                <input type="number" name="amount" id="input1"
                    placeholder="1000" step="0.01" required />
            </div>

            <div class="currency-row">
                <div class="input-group" style="margin-bottom:0;">
                    <label id="label2">மாற்று</label>
                    <select name="fromCurrency" id="fromCurrency">
                        <option value="INR" selected>🇮🇳 INR - Indian Rupee</option>
                        <option value="USD">🇺🇸 USD - US Dollar</option>
                        <option value="EUR">🇪🇺 EUR - Euro</option>
                        <option value="GBP">🇬🇧 GBP - British Pound</option>
                        <option value="AED">🇦🇪 AED - UAE Dirham</option>
                        <option value="SGD">🇸🇬 SGD - Singapore Dollar</option>
                        <option value="JPY">🇯🇵 JPY - Japanese Yen</option>
                        <option value="CAD">🇨🇦 CAD - Canadian Dollar</option>
                        <option value="AUD">🇦🇺 AUD - Australian Dollar</option>
                        <option value="SAR">🇸🇦 SAR - Saudi Riyal</option>
                    </select>
                </div>

                <button type="button" class="swap-btn" onclick="swapCurrencies()">⇄</button>

                <div class="input-group" style="margin-bottom:0;">
                    <label id="label3">இதற்கு</label>
                    <select name="toCurrency" id="toCurrency">
                        <option value="USD" selected>🇺🇸 USD - US Dollar</option>
                        <option value="INR">🇮🇳 INR - Indian Rupee</option>
                        <option value="EUR">🇪🇺 EUR - Euro</option>
                        <option value="GBP">🇬🇧 GBP - British Pound</option>
                        <option value="AED">🇦🇪 AED - UAE Dirham</option>
                        <option value="SGD">🇸🇬 SGD - Singapore Dollar</option>
                        <option value="JPY">🇯🇵 JPY - Japanese Yen</option>
                        <option value="CAD">🇨🇦 CAD - Canadian Dollar</option>
                        <option value="AUD">🇦🇺 AUD - Australian Dollar</option>
                        <option value="SAR">🇸🇦 SAR - Saudi Riyal</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="calc-btn" id="calcBtn">💱 மாற்று</button>
        </form>

        @if (ViewBag.Result != null)
        {
            <div class="result-box">
                <div class="from-amount">@ViewBag.Amount @ViewBag.FromCurrency =</div>
                <div class="to-amount">@ViewBag.Result @ViewBag.ToCurrency</div>
                <div class="rate-info">1 @ViewBag.FromCurrency = @ViewBag.Rate @ViewBag.ToCurrency</div>
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="error-box">⚠️ @ViewBag.Error</div>
        }

    </div>

</div>

<script>
    function swapCurrencies() {
        const from = document.getElementById('fromCurrency');
        const to = document.getElementById('toCurrency');
        const temp = from.value;
        from.value = to.value;
        to.value = temp;
    }

    const text = {
        ta: {
            title: "நாணய மாற்றி",
            subtitle: "உலக நாணயங்களை உடனே மாற்றுங்கள்",
            label1: "தொகை",
            label2: "மாற்று",
            label3: "இதற்கு",
            calcBtn: "💱 மாற்று"
        },
        en: {
            title: "Currency Converter",
            subtitle: "Convert world currencies instantly",
            label1: "Amount",
            label2: "From",
            label3: "To",
            calcBtn: "💱 Convert"
        }
    };

    function setLang(lang) {
        const t = text[lang];
        const ids = ['title','subtitle','label1','label2','label3','calcBtn'];
        ids.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.innerText = t[id];
        });
        document.getElementById('btn-ta').classList.toggle('active', lang === 'ta');
        document.getElementById('btn-en').classList.toggle('active', lang === 'en');
    }
</script>

</body>
</html>