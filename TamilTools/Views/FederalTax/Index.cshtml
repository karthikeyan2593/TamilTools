@model TamilTools.Models.FederalTaxViewModel

@{
    ViewData["Title"] = "Federal Tax Calculator";
}

<div class="container mt-5" style="max-width:1100px;">

    <div class="mb-4">
        <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-outline-secondary rounded-pill px-4">

            ← Back to Home

        </a>
    </div>



        <h2 class="text-center mb-2">
            Federal Tax Calculator
        </h2>

        <p class="text-center text-muted mb-4">
            Estimate your federal income tax and net income instantly.
        </p>

        <form method="post">

            <div class="mb-3">
                <label class="form-label">
                    Annual Income ($)
                </label>

                <input type="number"
                       step="0.01"
                       class="form-control"
                       asp-for="AnnualIncome"
                       required />
            </div>

            <div class="mb-4">
                <label class="form-label">
                    Filing Status
                </label>

                <select class="form-select"
                        asp-for="FilingStatus">

                    <option>Single</option>
                    <option>Married Filing Jointly</option>
                    <option>Head of Household</option>

                </select>
            </div>

            <button type="submit"
                    class="btn btn-primary w-100 rounded-pill">
                Calculate Tax
            </button>

        </form>

        @if (Model.FederalTax > 0)
        {
            <hr class="my-5" />

            <h3 class="mb-4 text-center">
                Tax Summary
            </h3>

            <div class="row text-center">

                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100 rounded-4">
                        <div class="card-body">

                            <h6 class="text-muted">
                                Federal Tax
                            </h6>

                            <h3 class="text-danger">
                                $@Model.FederalTax.ToString("N2")
                            </h3>

                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100 rounded-4">
                        <div class="card-body">

                            <h6 class="text-muted">
                                Net Income
                            </h6>

                            <h3 class="text-success">
                                $@Model.NetIncome.ToString("N2")
                            </h3>

                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm h-100 rounded-4">
                        <div class="card-body">

                            <h6 class="text-muted">
                                Effective Tax Rate
                            </h6>

                            <h3 class="text-primary">
                                @Model.EffectiveTaxRate.ToString("0.00")%
                            </h3>

                        </div>
                    </div>
                </div>

            </div>

            <div class="mt-4"
                 style="max-width:400px; margin:auto;">

                <canvas id="taxChart"></canvas>

            </div>
        }

    </div>

</div>

@if (Model.FederalTax > 0)
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const ctx = document.getElementById('taxChart');

        new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: ['Federal Tax', 'Net Income'],
        datasets: [{
        data: [
        @Model.FederalTax,
        @Model.NetIncome
        ],
        backgroundColor: [
        '#dc3545',
        '#198754'
        ],
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: {
        position: 'top'
        }
        }
        }
        });
    </script>
}

<style>

    .form-control:focus,
    .form-select:focus {
    box-shadow: 0 0 10px rgba(13,110,253,0.25);
    border-color: #0d6efd;
    }

    .card:hover {
    transform: translateY(-3px);
    transition: 0.3s ease;
    }

</style>