@model TamilTools.Models.FuturesPnLViewModel

@{
    ViewData["Title"] = "Crypto P&L Calculator";
    ViewData["Description"] = "Free Crypto P&L Calculator. Calculate crypto futures profit, loss and ROI instantly.";
    ViewData["Keywords"] = "crypto pnl calculator, futures calculator, crypto profit calculator";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #020617, #000814);
        color: white;
        min-height: 100vh;
    }

    .wrapper {
        width: 100%;
        max-width: 820px;
        margin: 50px auto;
        padding: 20px;
    }

    .card {
        background: linear-gradient(145deg, #0f172a, #111c44);
        border-radius: 28px;
        padding: 40px;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 0 40px rgba(249,115,22,0.08), 0 20px 60px rgba(0,0,0,0.5);
    }

    .home-btn {
        display: inline-block;
        margin-bottom: 20px;
        padding: 12px 18px;
        border-radius: 12px;
        background: #1e293b;
        color: white;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .home-btn:hover {
            background: #334155;
            color: white;
        }

    h1 {
        text-align: center;
        font-size: 56px;
        font-weight: 800;
        color: #f59e0b;
        margin-bottom: 12px;
        line-height: 1.2;
    }

    .subtitle {
        text-align: center;
        color: #cbd5e1;
        font-size: 18px;
        margin-bottom: 40px;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .input-group {
        margin-bottom: 25px;
    }

    label {
        display: block;
        margin-bottom: 10px;
        font-size: 16px;
        font-weight: 700;
        color: #cbd5e1;
    }

    input {
        width: 100%;
        padding: 18px;
        border-radius: 16px;
        border: 1px solid #334155;
        background: #1e293b;
        color: white;
        font-size: 22px;
        font-weight: 600;
        font-family: 'Segoe UI', sans-serif;
        transition: 0.3s;
    }

        input:focus {
            outline: none;
            border-color: #f59e0b;
            box-shadow: 0 0 20px rgba(245,158,11,0.3);
        }

        input::placeholder {
            color: #64748b;
            font-size: 18px;
        }

    .btn-calc {
        width: 100%;
        padding: 20px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(90deg, #f59e0b, #ea580c);
        color: white;
        font-size: 24px;
        font-weight: 800;
        cursor: pointer;
        margin-top: 10px;
        transition: 0.3s;
        box-shadow: 0 10px 30px rgba(249,115,22,0.35);
    }

        .btn-calc:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 40px rgba(249,115,22,0.45);
        }

    .results {
        margin-top: 35px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .result-box {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 25px;
        text-align: center;
    }

    .result-title {
        color: #94a3b8;
        font-size: 16px;
        margin-bottom: 15px;
        font-weight: 600;
    }

    .result-value {
        font-size: 40px;
        font-weight: 800;
        color: white;
    }

    .result-box:first-child .result-value {
        color: #ffffff;
    }

    .profit {
        color: #22c55e;
    }

    .loss {
        color: #ef4444;
    }

    .seo-box {
        margin-top: 35px;
        background: rgba(255,255,255,0.03);
        border-radius: 20px;
        padding: 30px;
        border: 1px solid rgba(255,255,255,0.06);
    }

        .seo-box h2 {
            font-size: 38px;
            margin-bottom: 20px;
            color: white;
        }

        .seo-box p {
            color: #cbd5e1;
            font-size: 18px;
            line-height: 1.8;
        }

    @@media(max-width:768px) {

        h1 {
            font-size: 38px;
        }

        .grid {
            grid-template-columns: 1fr;
        }

        .results {
            grid-template-columns: 1fr;
        }

        .card {
            padding: 25px;
        }

        input {
            font-size: 18px;
        }

        .btn-calc {
            font-size: 20px;
        }
    }
</style>

<div class="wrapper">

    <a href="/" class="home-btn">
        ← Home
    </a>

    <div class="card">

        <h1>💹 Crypto P&amp;L Calculator</h1>

        <p class="subtitle">
            Calculate crypto futures profit, loss and ROI instantly.
        </p>

        <form method="post">

            <div class="grid">

                <div class="input-group">
                    <label>Buy Price ($)</label>

                    <input asp-for="BuyPrice"
                           value=""
                           placeholder="Enter Buy Price" />
                </div>

                <div class="input-group">
                    <label>Sell Price ($)</label>

                    <input asp-for="SellPrice"
                           value=""
                           placeholder="Enter Sell Price" />
                </div>

                <div class="input-group">
                    <label>Investment Amount ($)</label>

                    <input asp-for="InvestmentAmount"
                           value=""
                           placeholder="Enter Investment Amount" />
                </div>

                <div class="input-group">
                    <label>Trading Fee (%)</label>

                    <input asp-for="TradingFee"
                           value=""
                           placeholder="0.10" />
                </div>

            </div>

            <button type="submit" class="btn-calc">
                Calculate P&amp;L
            </button>

        </form>

        <div class="results">

            <div class="result-box">
                <div class="result-title">
                    Final Amount
                </div>

                <div class="result-value">
                    $@Model.FinalAmount.ToString("0.00")
                </div>
            </div>

            <div class="result-box">
                <div class="result-title">
                    Profit / Loss
                </div>

                <div class="result-value @(Model.ProfitLoss >= 0 ? "profit" : "loss")">
                    $@Model.ProfitLoss.ToString("0.00")
                </div>
            </div>

            <div class="result-box">
                <div class="result-title">
                    ROI %
                </div>

                <div class="result-value @(Model.ROI >= 0 ? "profit" : "loss")">
                    @Model.ROI.ToString("0.00")%
                </div>
            </div>

        </div>

    </div>

    <div class="seo-box">

        <h2>
            What is Crypto P&amp;L Calculator?
        </h2>

        <p>
            Crypto P&amp;L Calculator helps traders calculate profit,
            loss and ROI from cryptocurrency trading instantly.
            You can calculate Bitcoin, Ethereum and futures trading
            profits accurately including trading fees.
        </p>

    </div>

</div>