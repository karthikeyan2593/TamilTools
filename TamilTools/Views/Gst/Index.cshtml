@{
    ViewData["Title"] = "GST Calculator";
}

<style>
    body {
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #11998e, #38ef7d);
        min-height: 100vh;
    }

    .gst-container {
        max-width: 500px;
        margin: 40px auto;
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    h1 {
        text-align: center;
        margin-bottom: 25px;
        color: #11998e;
        font-size: 32px;
        font-weight: bold;
    }

    label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
    }

    input, select {
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: 2px solid #ddd;
        margin-bottom: 20px;
        font-size: 16px;
    }

    button {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        background: #11998e;
        color: white;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
    }

    .result-box {
        margin-top: 25px;
        background: #f5f5f5;
        padding: 20px;
        border-radius: 14px;
    }

    .result-item {
        margin-bottom: 12px;
        font-size: 18px;
    }

    .home-btn {
        display: inline-block;
        margin-bottom: 20px;
        background: #11998e;
        color: white;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 600;
    }
</style>

<div class="gst-container">

    <a href="/" class="home-btn">← Home</a>

    <h1>GST Calculator</h1>

    <label>Amount</label>
    <input type="number" id="amount" placeholder="Enter amount">

    <label>GST %</label>
    <select id="gst">
        <option value="5">5%</option>
        <option value="12">12%</option>
        <option value="18">18%</option>
        <option value="28">28%</option>
    </select>

    <button onclick="calculateGST()">Calculate GST</button>

    <div class="result-box" id="result" style="display:none;">

        <div class="result-item">
            GST Amount: ₹<span id="gstAmount"></span>
        </div>

        <div class="result-item">
            CGST: ₹<span id="cgst"></span>
        </div>

        <div class="result-item">
            SGST: ₹<span id="sgst"></span>
        </div>

        <div class="result-item">
            Total Amount: ₹<span id="total"></span>
        </div>

    </div>

</div>

<script>
    function calculateGST() {

        let amount = parseFloat(document.getElementById("amount").value);
        let gst = parseFloat(document.getElementById("gst").value);

        if (!amount || amount <= 0) {
            alert("Enter valid amount");
            return;
        }

        let gstAmount = amount * gst / 100;
        let total = amount + gstAmount;
        let cgst = gstAmount / 2;
        let sgst = gstAmount / 2;

        document.getElementById("gstAmount").innerText = gstAmount.toFixed(2);
        document.getElementById("cgst").innerText = cgst.toFixed(2);
        document.getElementById("sgst").innerText = sgst.toFixed(2);
        document.getElementById("total").innerText = total.toFixed(2);

        document.getElementById("result").style.display = "block";
    }
</script>