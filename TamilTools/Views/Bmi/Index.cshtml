@{
    ViewData["Title"] = "BMI Calculator - TamilTools";
    ViewData["Description"] = "Free BMI Calculator. Calculate Body Mass Index in metric or imperial units.";
    ViewData["Keywords"] = "BMI calculator, body mass index, weight calculator, health calculator";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BMI Calculator</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #134e5e, #71b280);
            min-height: 100vh;
            padding: 30px 20px;
        }

        .container { max-width: 520px; margin: 0 auto; }

        .home-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.1);
            color: white;
            padding: 10px 16px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 16px;
        }

        .home-btn:hover { background: rgba(255,255,255,0.2); }

        .card {
            background: white;
            border-radius: 24px;
            padding: 36px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        }

        .card-header { text-align: center; margin-bottom: 28px; }
        .card-header .icon { font-size: 48px; margin-bottom: 12px; display: block; }
        .card-header h1 { font-size: 26px; color: #1a1a2e; font-weight: 800; margin-bottom: 6px; }
        .card-header p { color: #888; font-size: 14px; }

        /* Unit Toggle */
        .unit-toggle {
            display: flex;
            background: #f0f4f8;
            border-radius: 12px;
            padding: 4px;
            margin-bottom: 24px;
        }

        .unit-btn {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            background: transparent;
            color: #888;
            transition: all 0.3s;
        }

        .unit-btn.active {
            background: white;
            color: #134e5e;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .input-group { margin-bottom: 20px; }

        .input-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #444;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-wrapper { position: relative; }

        .input-suffix {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #134e5e;
            font-weight: 700;
            font-size: 14px;
        }

        .input-group input {
            width: 100%;
            padding: 14px 50px 14px 14px;
            border: 2px solid #eee;
            border-radius: 12px;
            font-size: 16px;
            color: #1a1a2e;
            font-weight: 600;
            transition: all 0.3s;
        }

        .input-group input:focus {
            outline: none;
            border-color: #134e5e;
            box-shadow: 0 0 0 4px rgba(19,78,94,0.1);
        }

        .calc-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #134e5e, #71b280);
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 8px;
        }

        .calc-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(19,78,94,0.4);
        }

        /* Result */
        .bmi-result {
            margin-top: 28px;
            border-radius: 20px;
            padding: 28px;
            text-align: center;
            color: white;
        }

        .bmi-result .bmi-num {
            font-size: 64px;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 8px;
        }

        .bmi-result .bmi-cat {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .bmi-result .bmi-sub {
            font-size: 13px;
            opacity: 0.8;
        }

        /* BMI Scale */
        .bmi-scale {
            margin-top: 20px;
            background: #f8f9ff;
            border-radius: 16px;
            padding: 20px;
            border: 2px solid #eef0ff;
        }

        .scale-title {
            font-size: 13px;
            font-weight: 700;
            color: #444;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 14px;
            text-align: center;
        }

        .scale-bar {
            height: 12px;
            border-radius: 6px;
            background: linear-gradient(to right, #4fc3f7, #66bb6a, #ffa726, #ef5350);
            margin-bottom: 8px;
            position: relative;
        }

        .scale-labels {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: #888;
            margin-bottom: 16px;
        }

        .scale-items { display: flex; flex-direction: column; gap: 8px; }

        .scale-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
        }

        .scale-item .range { font-weight: 600; color: #444; }
        .scale-item .cat { font-weight: 700; }

        @@media (max-width: 480px) {
            .card { padding: 24px; }
        }
    </style>
</head>
<body>
<div class="container">

    <a href="/" class="home-btn">← Home</a>

    <div class="card">
        <div class="card-header">
            <span class="icon">⚖️</span>
            <h1>BMI Calculator</h1>
            <p>Calculate your Body Mass Index</p>
        </div>

        <form method="post" action="/Bmi/Calculate">
            <div class="unit-toggle">
                <button type="button" class="unit-btn active" id="metricBtn"
                        onclick="setUnit('metric')">Metric (cm/kg)</button>
                <button type="button" class="unit-btn" id="imperialBtn"
                        onclick="setUnit('imperial')">Imperial (in/lbs)</button>
            </div>

            <input type="hidden" name="unit" id="unitInput" value="metric" />

            <div class="input-group">
                <label id="heightLabel">Height</label>
                <div class="input-wrapper">
                    <input type="number" name="height" id="heightInput"
                        placeholder="170" step="0.1"
                        value="@ViewBag.InputHeight" required />
                    <span class="input-suffix" id="heightUnit">cm</span>
                </div>
            </div>

            <div class="input-group">
                <label id="weightLabel">Weight</label>
                <div class="input-wrapper">
                    <input type="number" name="weight" id="weightInput"
                        placeholder="70" step="0.1"
                        value="@ViewBag.InputWeight" required />
                    <span class="input-suffix" id="weightUnit">kg</span>
                </div>
            </div>

            <button type="submit" class="calc-btn">⚖️ Calculate BMI</button>
        </form>

        @if (ViewBag.BMI != null)
        {
            <div class="bmi-result" style="background: @ViewBag.Color;">
                <div class="bmi-num">@ViewBag.BMI</div>
                <div class="bmi-cat">@ViewBag.Category</div>
                <div class="bmi-sub">Your BMI Score</div>
            </div>

            <div class="bmi-scale">
                <div class="scale-title">BMI Scale</div>
                <div class="scale-bar"></div>
                <div class="scale-labels">
                    <span>15</span>
                    <span>18.5</span>
                    <span>25</span>
                    <span>30</span>
                    <span>40</span>
                </div>
                <div class="scale-items">
                    <div class="scale-item" style="background: rgba(79,195,247,0.1);">
                        <span class="range">Below 18.5</span>
                        <span class="cat" style="color:#4fc3f7;">Underweight</span>
                    </div>
                    <div class="scale-item" style="background: rgba(102,187,106,0.1);">
                        <span class="range">18.5 – 24.9</span>
                        <span class="cat" style="color:#66bb6a;">Normal Weight ✅</span>
                    </div>
                    <div class="scale-item" style="background: rgba(255,167,38,0.1);">
                        <span class="range">25 – 29.9</span>
                        <span class="cat" style="color:#ffa726;">Overweight</span>
                    </div>
                    <div class="scale-item" style="background: rgba(239,83,80,0.1);">
                        <span class="range">30 and above</span>
                        <span class="cat" style="color:#ef5350;">Obese</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
    function setUnit(unit) {
        document.getElementById('unitInput').value = unit;

        if (unit === 'metric') {
            document.getElementById('metricBtn').classList.add('active');
            document.getElementById('imperialBtn').classList.remove('active');
            document.getElementById('heightUnit').innerText = 'cm';
            document.getElementById('weightUnit').innerText = 'kg';
            document.getElementById('heightInput').placeholder = '170';
            document.getElementById('weightInput').placeholder = '70';
        } else {
            document.getElementById('imperialBtn').classList.add('active');
            document.getElementById('metricBtn').classList.remove('active');
            document.getElementById('heightUnit').innerText = 'in';
            document.getElementById('weightUnit').innerText = 'lbs';
            document.getElementById('heightInput').placeholder = '67';
            document.getElementById('weightInput').placeholder = '154';
        }
    }

    @if (ViewBag.InputUnit != null && ViewBag.InputUnit == "imperial")
    {
        <text>setUnit('imperial');</text>
    }
</script>
</body>
</html>