<a href="/" class="home-btn">← Home</a>

<div class="card">

    <div class="card-header">
        <span class="icon">🏠</span>
        <h1>Mortgage Calculator</h1>
        <p>Calculate your monthly home loan payment</p>
    </div>

    <form method="post" action="/Mortgage/Calculate">

        <div class="input-group">
            <label>Home Price</label>

            <div class="input-wrapper">
                <span class="input-prefix">$</span>

                <input type="number"
                       name="homePrice"
                       placeholder="400000"
                       value="@ViewBag.InputHomePrice"
                       required />
            </div>
        </div>

        <div class="input-group">
            <label>Down Payment</label>

            <div class="input-wrapper">
                <span class="input-prefix">$</span>

                <input type="number"
                       name="downPayment"
                       placeholder="80000"
                       value="@ViewBag.InputDownPayment"
                       required />
            </div>
        </div>

        <div class="grid-2">

            <div class="input-group">
                <label>Interest Rate (%)</label>

                <div class="input-wrapper">
                    <span class="input-prefix">%</span>

                    <input type="number"
                           name="interestRate"
                           step="0.1"
                           placeholder="7.5"
                           value="@ViewBag.InputRate"
                           required />
                </div>
            </div>

            <div class="input-group">
                <label>Loan Term (Years)</label>

                <div class="input-wrapper">
                    <span class="input-prefix">📅</span>

                    <input type="number"
                           name="years"
                           placeholder="30"
                           value="@ViewBag.InputYears"
                           required />
                </div>
            </div>

        </div>

        <button type="submit" class="calc-btn">
            🏠 Calculate Mortgage
        </button>

    </form>
